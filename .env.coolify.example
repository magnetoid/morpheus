# Morpheus — Coolify environment template.
#
# Copy these values into Coolify's "Environment Variables" panel for the
# application. Anything prefixed with SERVICE_ is auto-managed by Coolify
# itself — DO NOT set it manually.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=

# Coolify injects ${SERVICE_FQDN_WEB} automatically. ALLOWED_HOSTS below is
# extra hosts you want to whitelist (apex domain, www, internal LB, etc).
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# ── Performance knobs (optional) ──────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60
CELERY_CONCURRENCY=4

# ── Storage (optional — keep media on S3 instead of local volume) ─────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# ── Observability (optional) ──────────────────────────────────────────────────
# Point at an OTLP collector if you have one (e.g. Tempo/Honeycomb/Grafana Cloud)
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Container image (optional) ────────────────────────────────────────────────
# Defaults to building the image from source. Override if you publish to GHCR.
# MORPHEUS_IMAGE=ghcr.io/magnetoid/morpheus:latest

# ── Auto-generated by Coolify (do NOT set manually) ───────────────────────────
# SERVICE_FQDN_WEB
# SERVICE_PASSWORD_POSTGRES
# SERVICE_PASSWORD_REDIS
