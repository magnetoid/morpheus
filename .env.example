DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Redis (for Celery task queue) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe Payments ────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── AI / LLM ───────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=morpheus-web

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@morpheusstore.io

# ── AWS S3 (optional media storage) ───────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# ── Store Config ───────────────────────────────────────────────────────────────
STORE_NAME=Morpheus Store
STORE_CURRENCY=USD
STORE_COUNTRY=US
STORE_TAX_RATE=0.0

# ── Plugin & Theme System ──────────────────────────────────────────────────────
MORPHEUS_ACTIVE_THEME=aurora
MORPHEUS_PLUGINS_ENABLED=
